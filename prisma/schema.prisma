generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trend {
  id            String   @id
  title         String
  url           String
  source        String
  stars         Int      @default(0)
  comments      Int      @default(0)
  score         Int      @default(0)
  summary       String?
  category      String
  postCreatedAt DateTime
  keywords      String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
